{
  "version": 2,
  "routes": [
    {
      "src": "^/sw.js$",
      "headers": { "cache-control": "public, max-age=0, must-revalidate" },
      "dest": "/sw.js"
    },
    {
      "src": "^/OneSignalSDKWorker.js$",
      "headers": { "cache-control": "public, max-age=0, must-revalidate" },
      "dest": "/OneSignalSDKWorker.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/.*",
      "dest": "/index.html"
    }
  ]
}